<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Datos Escuela</title>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand" href="/">
Control Escolar
</a>

<div class="navbar-nav d-flex flex-row flex-wrap">

<a class="nav-link me-3" href="/asignaturas">
Asignaturas
</a>

<a class="nav-link me-3" href="/horarios">
Horarios
</a>

<a class="nav-link me-3" href="/intendencia">
Intendencia
</a>

<a class="nav-link me-3" href="/estados">
    Estados
</a>

<a class="nav-link me-3" href="/municipios">
Municipios
</a>

<a class="nav-link me-3" href="/localidades">
    Localidades
</a>

<a class="nav-link me-3" href="/generos">
    Géneros
</a>

<a class="nav-link me-3" href="/datospersonales">Datos Personales</a>

<a class="nav-link me-3" href="/tipopersonal">Tipo Personal</a>

<a class="nav-link me-3" href="/personal">

Personal

</a>

<a class="nav-link me-3" href="/carreras">

Carreras

</a>

<a class="nav-link me-3" href="/alumnos">

Alumnos

</a>

<a class="nav-link active" href="/escuela">

Escuela

</a>

</div>
</div>
</nav>


<div class="container mt-4">

<a
href="/escuela/create"
class="btn btn-success mb-3">

Nuevo Registro

</a>


<div class="table-responsive">

<table class="table table-bordered table-striped text-center">

<thead class="table-primary">

<tr>

<th>CCT</th>

<th>Nombre</th>

<th>Teléfono</th>

<th>Email</th>

<th>Calle</th>

<th>NumE</th>

<th>NumI</th>

<th>CP</th>

<th>Acciones</th>

</tr>

</thead>

<tbody>

<% results.forEach((escuela)=>{ %>

<tr>

<td><%= escuela.cct %></td>

<td><%= escuela.nombre %></td>

<td><%= escuela.telefono %></td>

<td><%= escuela.email %></td>

<td><%= escuela.calle %></td>

<td><%= escuela.numE %></td>

<td><%= escuela.numI %></td>

<td><%= escuela.cp %></td>

<td>

<a
href="/escuela/edit/<%= escuela.cct %>"
class="btn btn-warning btn-sm">

Editar

</a>
<% if(rol === 'Admin'){ %>
<a
href="/escuela/delete/<%= escuela.cct %>"
class="btn btn-danger btn-sm">

Eliminar

</a>
<% } %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</body>
</html>