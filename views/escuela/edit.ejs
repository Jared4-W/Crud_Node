<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Editar Escuela</title>

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-7">

<div class="card shadow">

<div class="card-header bg-warning">

Editar Registro Escuela

</div>

<div class="card-body">

<form action="/escuela/update" method="POST">


<input
type="text"
name="cct"
value="<%= escuela.cct %>"
readonly
class="form-control mb-3">


<input
type="text"
name="nombre"
value="<%= escuela.nombre %>"
class="form-control mb-3">


<input
type="text"
name="telefono"
value="<%= escuela.telefono %>"
class="form-control mb-3">


<input
type="email"
name="email"
value="<%= escuela.email %>"
class="form-control mb-3">


<input
type="text"
name="calle"
value="<%= escuela.calle %>"
class="form-control mb-3">


<input
type="number"
name="numE"
value="<%= escuela.numE %>"
class="form-control mb-3">


<input
type="number"
name="numI"
value="<%= escuela.numI %>"
class="form-control mb-3">


<input
type="number"
name="cp"
value="<%= escuela.cp %>"
class="form-control mb-3">


<button class="btn btn-primary">

Actualizar

</button>

<a href="/escuela" class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>