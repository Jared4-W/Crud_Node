<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Editar Tipo Personal</title>

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow">

<div class="card-header bg-warning">

Editar Tipo Personal

</div>

<div class="card-body">

<form action="/tipopersonal/update" method="POST">

<input
type="hidden"
name="idTipo"
value="<%= tipo.idTipo %>">


<div class="mb-3">

<label class="form-label">

Tipo de Personal

</label>

<input
type="text"
name="personal"
value="<%= tipo.personal %>"
class="form-control"
required>

</div>


<button class="btn btn-primary">

Actualizar

</button>

<a
href="/tipopersonal"
class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>