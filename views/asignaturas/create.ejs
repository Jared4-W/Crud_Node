<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1">

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
rel="stylesheet"
>

<title>Nueva Asignatura</title>

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card border-secondary shadow">

                <div class="card-header bg-primary text-white">

                    Nueva Asignatura

                </div>

                <div class="card-body">

                    <form action="/asignaturas/save" method="POST">

                        <div class="mb-3">

                            <label
                            for="nombresMaterias"
                            class="form-label"
                            >
                                Nombre de la materia
                            </label>

                            <input
                            type="text"
                            class="form-control"
                            id="nombresMaterias"
                            name="nombresMaterias"
                            required
                            autofocus>

                        </div>


                        <div class="mb-3">

                            <label
                            for="horasTotales"
                            class="form-label"
                            >
                                Horas Totales
                            </label>

                            <input
                            type="number"
                            class="form-control"
                            id="horasTotales"
                            name="horasTotales"
                            required>

                        </div>


                        <button
                        type="submit"
                        class="btn btn-success"
                        >
                            Guardar
                        </button>

                        <a
                        href="/asignaturas"
                        class="btn btn-secondary"
                        >
                            Cancelar
                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

</body>
</html>

