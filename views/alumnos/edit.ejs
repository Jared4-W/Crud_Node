<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow">

<div class="card-header bg-warning">

Editar Alumno

</div>

<div class="card-body">

<form action="/alumnos/update" method="POST">


<input
type="text"
name="matricula"
value="<%= alumno.matricula %>"
readonly
class="form-control mb-3">


<select
name="idCarrera"
class="form-select mb-3">

<% carreras.forEach((carrera)=>{ %>

<option
value="<%= carrera.idCarrera %>"
<%= carrera.idCarrera == alumno.idCarrera ? 'selected' : '' %>>

<%= carrera.idCarrera %>

</option>

<% }) %>

</select>


<select
name="idDatosP"
class="form-select mb-3">

<% datos.forEach((dato)=>{ %>

<option
value="<%= dato.idDatosP %>"
<%= dato.idDatosP == alumno.idDatosP ? 'selected' : '' %>>

<%= dato.idDatosP %>

</option>

<% }) %>

</select>


<input
type="text"
name="status"
value="<%= alumno.status %>"
class="form-control mb-3">


<button class="btn btn-primary">

Actualizar

</button>

<a href="/alumnos" class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>