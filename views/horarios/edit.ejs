<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow">

<div class="card-header bg-warning">

Editar Horario

</div>

<div class="card-body">

<form action="/horarios/update" method="POST">

<input
type="hidden"
name="idHorario"
value="<%= horario.idHorario %>">


<div class="mb-3">

<label>Día</label>

<input
type="text"
name="dia"
value="<%= horario.dia %>"
class="form-control">

</div>


<div class="mb-3">

<label>Hora Inicio</label>

<input
type="time"
name="horaInicio"
value="<%= horario.horaInicio %>"
class="form-control">

</div>


<div class="mb-3">

<label>Hora Fin</label>

<input
type="time"
name="horaFin"
value="<%= horario.horaFin %>"
class="form-control">

</div>


<div class="mb-3">

<label>Aula</label>

<input
type="text"
name="aula"
value="<%= horario.aula %>"
class="form-control">

</div>

<button class="btn btn-primary">

Actualizar

</button>

<a href="/horarios" class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>