<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow">

<div class="card-header bg-success text-white">

Nuevo Personal

</div>

<div class="card-body">

<form action="/personal/save" method="POST">

<select
name="idDatosP"
class="form-select mb-3"
required>

<option value="">

Seleccione ID Datos Personales

</option>

<% datos.forEach((dato)=>{ %>

<option value="<%= dato.idDatosP %>">

<%= dato.idDatosP %>

</option>

<% }) %>

</select>



<select
name="idTipo"
class="form-select mb-3"
required>

<option value="">

Seleccione Tipo Personal

</option>

<% tipos.forEach((tipo)=>{ %>

<option value="<%= tipo.idTipo %>">

<%= tipo.personal %>

</option>

<% }) %>

</select>



<input
type="text"
name="claveEmp"
placeholder="Clave empleado"
class="form-control mb-3"
required>


<select
name="status"
class="form-select mb-3">

<option value="1">

Activo

</option>

<option value="0">

Inactivo

</option>

</select>


<button class="btn btn-success">

Guardar

</button>

<a href="/personal" class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>