<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow">

<div class="card-header bg-warning">

Editar Personal

</div>

<div class="card-body">

<form action="/personal/update" method="POST">

<input
type="hidden"
name="idPersonal"
value="<%= empleado.idPersonal %>">


<select
name="idDatosP"
class="form-select mb-3">

<% datos.forEach((dato)=>{ %>

<option
value="<%= dato.idDatosP %>"
<%= dato.idDatosP == empleado.idDatosP ? 'selected' : '' %>>

<%= dato.idDatosP %>

</option>

<% }) %>

</select>



<select
name="idTipo"
class="form-select mb-3">

<% tipos.forEach((tipo)=>{ %>

<option
value="<%= tipo.idTipo %>"
<%= tipo.idTipo == empleado.idTipo ? 'selected' : '' %>>

<%= tipo.personal %>

</option>

<% }) %>

</select>


<input
type="text"
name="claveEmp"
value="<%= empleado.claveEmp %>"
class="form-control mb-3">


<select
name="status"
class="form-select mb-3">

<option
value="1"
<%= empleado.status == 1 ? 'selected' : '' %>>

Activo

</option>

<option
value="0"
<%= empleado.status == 0 ? 'selected' : '' %>>

Inactivo

</option>

</select>


<button class="btn btn-primary">

Actualizar

</button>

<a href="/personal" class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>