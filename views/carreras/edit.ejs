<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
rel="stylesheet">

<title>Editar Carrera</title>

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow">

<div class="card-header bg-warning">

Editar Carrera

</div>

<div class="card-body">

<form action="/carreras/update" method="POST">

<input
type="hidden"
name="idCarrera"
value="<%= carrera.idCarrera %>">


<div class="mb-3">

<label class="form-label">

Nombre Carrera

</label>

<input
type="text"
name="nombreCarreras"
value="<%= carrera.nombreCarreras %>"
class="form-control"
required>

</div>


<div class="mb-3">

<label class="form-label">

Estatus

</label>

<select
name="estatus"
class="form-select">

<option
value="1"
<%= carrera.estatus == 1 ? 'selected' : '' %>>

Activa

</option>

<option
value="0"
<%= carrera.estatus == 0 ? 'selected' : '' %>>

Inactiva

</option>

</select>

</div>


<button class="btn btn-primary">

Actualizar

</button>

<a
href="/carreras"
class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>