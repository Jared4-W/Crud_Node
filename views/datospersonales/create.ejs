<!doctype html>
<html lang="es">
<head>

<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Nuevo Registro</title>

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-8">

<div class="card shadow">

<div class="card-header bg-primary text-white">

Nuevo Registro

</div>

<div class="card-body">

<form action="/datospersonales/save" method="POST">

<input name="nombre" class="form-control mb-3" placeholder="Nombre" required>

<input name="apellidoP" class="form-control mb-3" placeholder="Apellido Paterno" required>

<input name="apellidoM" class="form-control mb-3" placeholder="Apellido Materno" required>

<input type="date" name="fechaNacimiento" class="form-control mb-3" required>

<input name="telefono" class="form-control mb-3" placeholder="Teléfono">

<input name="email" class="form-control mb-3" placeholder="Email">

<input name="curp" class="form-control mb-3" placeholder="CURP">

<input name="calle" class="form-control mb-3" placeholder="Calle">

<input type="number" name="numE" class="form-control mb-3" placeholder="Número Exterior">

<input type="number" name="numI" class="form-control mb-3" placeholder="Número Interior">

<input type="number" name="cp" class="form-control mb-3" placeholder="Código Postal">

<select name="idEstado" class="form-select mb-3" required>

<option value="">Seleccione Estado</option>

<% estados.forEach((estado)=>{ %>

<option value="<%= estado.idEstado %>">
<%= estado.nombre %>
</option>

<% }) %>

</select>


<select name="idMunicipio" class="form-select mb-3" required>

<option value="">Seleccione Municipio</option>

<% municipios.forEach((municipio)=>{ %>

<option value="<%= municipio.idMunicipio %>">
<%= municipio.nombre %>
</option>

<% }) %>

</select>


<select name="idLocalidad" class="form-select mb-3" required>

<option value="">Seleccione Localidad</option>

<% localidades.forEach((localidad)=>{ %>

<option value="<%= localidad.idLocalidad %>">
<%= localidad.nombre %>
</option>

<% }) %>

</select>


<select name="idGenero" class="form-select mb-3" required>

<option value="">Seleccione Género</option>

<% generos.forEach((genero)=>{ %>

<option value="<%= genero.idGenero %>">
<%= genero.genero %>
</option>

<% }) %>

</select>


<button class="btn btn-success">

Guardar

</button>

<a href="/datospersonales" class="btn btn-secondary">

Cancelar

</a>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>